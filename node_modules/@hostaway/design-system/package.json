{
  "name": "@hostaway/design-system",
  "version": "2.75.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hostaway/design-system"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "private": false,
  "description": "Hostaway Design System with UntitledUI",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "icons": [
        "./dist/icons.d.ts"
      ],
      "*": [
        "./dist/components/*/index.d.ts",
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.esm.js",
      "require": "./dist/icons.cjs.js"
    },
    "./theme.css": "./dist/theme.css",
    "./dist/theme.css": "./dist/theme.css",
    "./animations.css": "./dist/animations.css",
    "./dist/animations.css": "./dist/animations.css",
    "./tailwind-plugin": {
      "types": "./dist/tailwind-plugin.d.ts",
      "require": "./dist/tailwind-plugin.js"
    },
    "./*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.esm.js",
      "require": "./dist/components/*/index.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs && node scripts/build-declarations.mjs && cp src/styles/theme.css dist/theme.css && cp src/styles/animations.css dist/animations.css",
    "build:watch": "rollup -c rollup.config.mjs --watch && node scripts/build-declarations.mjs && cp src/styles/theme.css dist/theme.css && cp src/styles/animations.css dist/animations.css",
    "dev": "storybook dev -p 6006",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "typecheck:validate": "tsc --noEmit --project tsconfig.validate.json",
    "lint": "eslint src --ext .ts,.tsx --ignore-pattern '**/*.stories.{ts,tsx}'",
    "lint:fix": "eslint src --ext .ts,.tsx --fix --ignore-pattern '**/*.stories.{ts,tsx}'",
    "lint:check": "eslint src --ext .ts,.tsx --max-warnings 0 --ignore-pattern '**/*.stories.{ts,tsx}'",
    "validate": "yarn typecheck:validate && yarn lint && rollup -c rollup.config.mjs --validate",
    "check": "yarn validate",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "publish:package": "yarn validate && yarn clean && yarn build && yarn publish --non-interactive",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:serve": "serve storybook-static",
    "story:component": "node scripts/generate-story.js component",
    "story:example": "node scripts/generate-story.js example",
    "chromatic": "chromatic --exit-zero-on-changes",
    "test-storybook": "test-storybook",
    "test-storybook:ci": "test-storybook --maxWorkers=2",
    "docker:build": "docker build --build-arg GH_PACKAGES_TOKEN=\"$GH_PACKAGES_TOKEN\" -t hostaway-ds-storybook .",
    "docker:run": "docker run --name hostaway-ds-storybook-container -p 6060:6060 hostaway-ds-storybook",
    "docker:dev": "yarn docker:build && yarn docker:run",
    "docker:clean": "docker rm -f hostaway-ds-storybook-container || true",
    "docker:restart": "yarn docker:clean && yarn docker:dev",
    "hostay:deploy": "read -p 'Enter deployment name: ' name && hostay images deploy -r storybook -n \"$name\" -t \"$name\"",
    "hostay:start": "hostay app launch -r storybook -n \"latest\" -t \"latest\" -p 6060",
    "prepare": "husky",
    "size": "size-limit"
  },
  "peerDependencies": {
    "react": ">=18.0",
    "react-dom": ">=18.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^28.0.5",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@rsbuild/core": "^1.7.5",
    "@rsbuild/plugin-react": "^1.4.6",
    "@size-limit/file": "^12.0.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-designs": "^11.1.3",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/test-runner": "^0.24.3",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@untitledui/file-icons": "^0.0.9",
    "axe-playwright": "^2.2.2",
    "chromatic": "^16.1.0",
    "css-loader": "^7.1.3",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "10.3.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "16",
    "motion": "^12.33.0",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.7.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rollup": "^4.60.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "size-limit": "^12.0.0",
    "storybook": "^10.3.6",
    "storybook-react-rsbuild": "^3.3.2",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.1.2",
    "typescript": "^5.0.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tiptap/extension-image": "^3.13.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-text-align": "^3.21.0",
    "@tiptap/extension-text-style": "^3.20.4",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.13.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@untitledui/icons": "^0.0.22",
    "react-aria-components": "^1.16.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-react-aria-components": "^2.0.1",
    "ts-pattern": "^5.9.0",
    "tw-animate-css": "^1.4.0"
  },
  "size-limit": [
    {
      "name": "Main (ESM)",
      "path": "dist/index.esm.js"
    },
    {
      "name": "Main (CJS)",
      "path": "dist/index.cjs.js"
    },
    {
      "name": "Icons (ESM)",
      "path": "dist/icons.esm.js"
    },
    {
      "name": "Tailwind Plugin",
      "path": "dist/tailwind-plugin.js"
    },
    {
      "name": "Theme CSS",
      "path": "dist/theme.css",
      "brotli": false,
      "gzip": false
    }
  ],
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "license": "UNLICENSED",
  "resolutions": {
    "globals": "^15.14.0"
  }
}
